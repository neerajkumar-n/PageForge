# PageForge — Environment Variables
# Copy this file to .env.local and fill in your values.

# ──────────────────────────────────────────────
# AI Provider Configuration
# ──────────────────────────────────────────────

# Your Anthropic API key (required unless MOCK_AGENTS=true)
AI_API_KEY=your_api_key_here

# API base URL — supports any OpenAI-compatible endpoint
# Default: Anthropic's API. Change to use Azure, AWS Bedrock proxy, or local Ollama.
AI_BASE_URL=https://api.anthropic.com

# Model to use for all agents
# Anthropic: claude-sonnet-4-20250514 | claude-opus-4-20250514 | claude-haiku-4-5-20251001
# Override with any model ID supported by your AI_BASE_URL endpoint
AI_MODEL=claude-sonnet-4-20250514

# Max tokens per agent response (increase for longer pages, decrease to save cost)
AI_MAX_TOKENS=8000

# ──────────────────────────────────────────────
# Development
# ──────────────────────────────────────────────

# Set to true to run all agents with realistic mock data (no API calls, no cost)
# Perfect for UI development and demos
MOCK_AGENTS=false
